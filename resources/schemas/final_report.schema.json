{
  "$defs": {
    "ArtifactLink": {
      "additionalProperties": false,
      "properties": {
        "bytes": {
          "minimum": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes"
      ],
      "title": "ArtifactLink",
      "type": "object"
    },
    "ReportNarrative": {
      "additionalProperties": false,
      "description": "Optional model-assisted prose; authoritative statuses remain deterministic.",
      "properties": {
        "executive_summary": {
          "title": "Executive Summary",
          "type": "string"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "methodology_summary": {
          "title": "Methodology Summary",
          "type": "string"
        }
      },
      "required": [
        "executive_summary",
        "methodology_summary"
      ],
      "title": "ReportNarrative",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Authoritative model for ``resources/schemas/final_report.schema.json``.",
  "properties": {
    "artifacts": {
      "additionalProperties": {
        "$ref": "#/$defs/ArtifactLink"
      },
      "title": "Artifacts",
      "type": "object"
    },
    "backend": {
      "additionalProperties": true,
      "title": "Backend",
      "type": "object"
    },
    "backend_history": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Backend History",
      "type": "array"
    },
    "configuration": {
      "additionalProperties": true,
      "title": "Configuration",
      "type": "object"
    },
    "execution_issues": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Execution Issues",
      "type": "array"
    },
    "knowledge_graph": {
      "additionalProperties": true,
      "title": "Knowledge Graph",
      "type": "object"
    },
    "lean_consent": {
      "additionalProperties": true,
      "title": "Lean Consent",
      "type": "object"
    },
    "lean_status": {
      "title": "Lean Status",
      "type": "string"
    },
    "literature_resolution_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Literature Resolution Summary"
    },
    "literature_status": {
      "default": "unknown",
      "title": "Literature Status",
      "type": "string"
    },
    "manuscript_findings": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Manuscript Findings",
      "type": "array"
    },
    "manuscript_status": {
      "title": "Manuscript Status",
      "type": "string"
    },
    "narrative": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReportNarrative"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "original_problem": {
      "default": "",
      "title": "Original Problem",
      "type": "string"
    },
    "problem_clarification": {
      "additionalProperties": true,
      "title": "Problem Clarification",
      "type": "object"
    },
    "prompt_validation_warnings": {
      "items": {
        "type": "string"
      },
      "title": "Prompt Validation Warnings",
      "type": "array"
    },
    "publication_status": {
      "default": "NOT_ASSESSED",
      "title": "Publication Status",
      "type": "string"
    },
    "reproducibility": {
      "items": {
        "type": "string"
      },
      "title": "Reproducibility",
      "type": "array"
    },
    "research_checkpoint": {
      "additionalProperties": true,
      "title": "Research Checkpoint",
      "type": "object"
    },
    "resume_action": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resume Action"
    },
    "retriable_actions": {
      "items": {
        "type": "string"
      },
      "title": "Retriable Actions",
      "type": "array"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "scientific_status": {
      "title": "Scientific Status",
      "type": "string"
    },
    "skipped_stages": {
      "items": {
        "additionalProperties": {
          "type": "string"
        },
        "type": "object"
      },
      "title": "Skipped Stages",
      "type": "array"
    },
    "source_provenance_warnings": {
      "items": {
        "type": "string"
      },
      "title": "Source Provenance Warnings",
      "type": "array"
    },
    "stage_statuses": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Stage Statuses",
      "type": "object"
    },
    "strongest_result": {
      "title": "Strongest Result",
      "type": "string"
    },
    "unresolved_obligations": {
      "items": {
        "type": "string"
      },
      "title": "Unresolved Obligations",
      "type": "array"
    },
    "usage": {
      "additionalProperties": true,
      "title": "Usage",
      "type": "object"
    },
    "workflow_status": {
      "default": "COMPLETE",
      "title": "Workflow Status",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "scientific_status",
    "manuscript_status",
    "lean_status",
    "strongest_result",
    "unresolved_obligations",
    "artifacts"
  ],
  "title": "FinalReport",
  "type": "object"
}
