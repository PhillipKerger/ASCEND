{
  "$defs": {
    "AuditDecision": {
      "enum": [
        "pass",
        "repairable",
        "fail",
        "partial_only"
      ],
      "title": "AuditDecision",
      "type": "string"
    },
    "AuditIssue": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "title": "Description",
          "type": "string"
        },
        "repair": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Repair"
        },
        "severity": {
          "enum": [
            "blocking",
            "advisory"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "severity",
        "description",
        "repair"
      ],
      "title": "AuditIssue",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "audit_role": {
      "title": "Audit Role",
      "type": "string"
    },
    "checks_performed": {
      "items": {
        "type": "string"
      },
      "title": "Checks Performed",
      "type": "array"
    },
    "issues": {
      "items": {
        "$ref": "#/$defs/AuditIssue"
      },
      "title": "Issues",
      "type": "array"
    },
    "rationale": {
      "title": "Rationale",
      "type": "string"
    },
    "target_matches": {
      "title": "Target Matches",
      "type": "boolean"
    },
    "unresolved_obligations": {
      "items": {
        "type": "string"
      },
      "title": "Unresolved Obligations",
      "type": "array"
    },
    "verdict": {
      "$ref": "#/$defs/AuditDecision"
    }
  },
  "required": [
    "verdict",
    "issues",
    "unresolved_obligations",
    "target_matches",
    "audit_role",
    "rationale",
    "checks_performed"
  ],
  "title": "AuditVerdict",
  "type": "object"
}
